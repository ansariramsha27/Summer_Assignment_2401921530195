class Solution {
public:
    int maxProfit(vector<int>& prices) {
        int length = prices.size();
        int profit = 0;
        if(length == 0){
            return profit;
        }
        
        int minPrice = prices[0];
        for(int i = 1;i < length;i++){
            profit = max(profit,prices[i] - minPrice);
            minPrice = min(minPrice,prices[i]);
            
        }
        return profit;
    }
};
